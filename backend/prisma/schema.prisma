generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String
  password        String
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  isActive        Boolean          @default(true) @map("is_active")
  zone            String?
  createdAgencies Agency[]         @relation("AgencyCreator")
  createdClients  Client[]         @relation("ClientCreator")
  movements       Movement[]
  orders          Order[]          @relation("UserOrders")
  processAudits   ProcessAudit[]
  samplesReviewed ProductSample[]  @relation("SampleReviewer")
  samplesCreated  ProductSample[]  @relation("SampleCreator")
  purchases       Purchase[]
  qualityControls QualityControl[] @relation("QualityConfirmedBy")
  returnRequests  ReturnRequest[]  @relation("UserReturnRequests")
  sales           Sale[]           @relation("UserSales")
  roles           Role[]           @relation("UserRoles")

  @@map("users")
}

model Role {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  users       User[]  @relation("UserRoles")

  @@map("roles")
}

model Product {
  id               String            @id @default(cuid())
  sku              String            @unique
  name             String
  category         String
  description      String?
  purchasePrice    Float             @map("purchase_price")
  sellingPrice     Float             @map("selling_price")
  minStock         Float             @default(5) @map("min_stock")
  isActive         Boolean           @default(true) @map("is_active")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  inventoryType    String            @default("TERMINADOS") @map("inventory_type")
  op               String?
  colors           String[]          @default([])
  sizes            String[]          @default([])
  entalle          String?
  realPrice        Float             @default(0.0) @map("real_price")
  processAudits    ProcessAudit[]
  variants         ProductVariant[]
  productionOrders ProductionOrder[]
  purchaseItems    PurchaseItem[]
  sampleUsage      SampleMaterial[]

  @@map("products")
}

model ProductVariant {
  id            String         @id @default(cuid())
  productId     String         @map("product_id")
  size          String
  color         String
  stock         Float          @default(0)
  variantSku    String         @unique @map("variant_sku")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  op            String?        @map("op")
  movements     Movement[]
  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  purchaseItems PurchaseItem[]
  saleItems     SaleItem[]

  @@unique([productId, size, color])
  @@index([variantSku])
  @@map("product_variants")
}

model ProductionOrder {
  id        String   @id @default(cuid())
  opNumber  String   @unique @map("op_number")
  productId String   @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("production_orders")
}

model Movement {
  id            String         @id @default(cuid())
  type          String
  quantity      Float
  reason        String
  reference     String?
  previousStock Float          @map("previous_stock")
  newStock      Float          @map("new_stock")
  variantId     String         @map("variant_id")
  userId        String         @map("user_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  user          User           @relation(fields: [userId], references: [id])
  variant       ProductVariant @relation(fields: [variantId], references: [id])

  @@index([variantId])
  @@index([createdAt])
  @@map("movements")
}

model Purchase {
  id            String         @id @default(cuid())
  invoiceNumber String?        @map("invoice_number")
  totalAmount   Float          @default(0) @map("total_amount")
  userId        String         @map("user_id")
  notes         String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  type          String         @default("PURCHASE")
  op            String?
  status        String         @default("EN_CALIDAD")
  supplierId    String?        @map("supplier_id")
  items         PurchaseItem[]
  supplier      Supplier?      @relation(fields: [supplierId], references: [id])
  user          User           @relation(fields: [userId], references: [id])

  @@map("purchases")
}

model PurchaseItem {
  id             String          @id @default(cuid())
  purchaseId     String          @map("purchase_id")
  productId      String?         @map("product_id")
  variantId      String?         @map("variant_id")
  quantity       Float
  price          Float
  createdAt      DateTime        @default(now()) @map("created_at")
  category       String
  description    String?
  name           String
  unit           String?
  status         String          @default("EN_CALIDAD")
  product        Product?        @relation(fields: [productId], references: [id])
  purchase       Purchase        @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  variant        ProductVariant? @relation(fields: [variantId], references: [id])
  qualityControl QualityControl?

  @@map("purchase_items")
}

model QualityControl {
  id              String       @id @default(cuid())
  purchaseItemId  String       @unique @map("purchase_item_id")
  status          String
  observations    String?
  rejectionReason String?      @map("rejection_reason")
  confirmedById   String?      @map("confirmed_by_id")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  confirmedBy     User?        @relation("QualityConfirmedBy", fields: [confirmedById], references: [id])
  purchaseItem    PurchaseItem @relation(fields: [purchaseItemId], references: [id], onDelete: Cascade)

  @@map("quality_controls")
}

model Supplier {
  id             String     @id @default(cuid())
  documentType   String     @default("RUC") @map("document_type")
  documentNumber String     @unique @map("document_number")
  name           String
  contactName    String?    @map("contact_name")
  email          String?
  phone          String?
  address        String?
  category       String?
  isActive       Boolean    @default(true) @map("is_active")
  notes          String?
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  purchases      Purchase[]

  @@map("suppliers")
}

model ProcessAudit {
  id              String         @id @default(cuid())
  productId       String?        @map("product_id")
  sampleId        String?        @map("sample_id")
  op              String
  process         String
  externalCompany String?        @map("external_company")
  inspectorId     String         @map("inspector_id")
  auditDate       DateTime       @default(now()) @map("audit_date")
  result          String         @default("PENDIENTE")
  quantityGood    Float          @default(0) @map("quantity_good")
  quantityProcess Float          @default(0) @map("quantity_process")
  quantitySecond  Float          @default(0) @map("quantity_second")
  totalQuantity   Float          @default(0) @map("total_quantity")
  observations    String?
  evidences       String[]
  checklist       Json?
  status          String         @default("EN_PROCESO")
  approvalStatus  String         @default("PENDIENTE") @map("approval_status")
  approvedAt      DateTime?      @map("approved_at")
  adminStatus     String         @default("PENDIENTE") @map("admin_status")
  adminNotes      String?        @map("admin_notes")
  adminUserId     String?        @map("admin_user_id")
  logisticsStatus String         @default("PENDIENTE") @map("logistics_status")
  receivedAt      DateTime?      @map("received_at")
  processHistory  Json?          @map("process_history")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  servicePrice    Float?         @default(0) @map("service_price")
  qualitySizeData Json?          @map("quality_size_data")
  findings        AuditFinding[]
  inspector       User           @relation(fields: [inspectorId], references: [id])
  product         Product?       @relation(fields: [productId], references: [id])
  sample          ProductSample? @relation(fields: [sampleId], references: [id])

  @@map("process_audits")
}

model Notification {
  id          String   @id @default(cuid())
  title       String
  message     String
  type        String
  referenceId String?  @map("reference_id")
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")
  targetRole  String?  @map("target_role")
  userId      String?  @map("user_id")

  @@map("notifications")
}

model AuditFinding {
  id                String             @id @default(cuid())
  auditId           String             @map("audit_id")
  description       String
  severity          String
  responsibleArea   String             @map("responsible_area")
  date              DateTime           @default(now())
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  audit             ProcessAudit       @relation(fields: [auditId], references: [id], onDelete: Cascade)
  correctiveActions CorrectiveAction[]

  @@map("audit_findings")
}

model CorrectiveAction {
  id              String       @id @default(cuid())
  findingId       String       @map("finding_id")
  action          String
  responsibleId   String?      @map("responsible_id")
  responsibleName String?      @map("responsible_name")
  deadline        DateTime?
  status          String       @default("PENDIENTE")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  finding         AuditFinding @relation(fields: [findingId], references: [id], onDelete: Cascade)

  @@map("corrective_actions")
}

model Client {
  id             String          @id @default(cuid())
  documentType   String          @default("DNI") @map("document_type")
  documentNumber String          @unique @map("document_number")
  name           String
  email          String?
  phone          String?
  address        String?
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  createdById    String?         @map("created_by_id")
  zone           String?
  address2       String?
  createdBy      User?           @relation("ClientCreator", fields: [createdById], references: [id])
  letraGroups    LetraGroup[]
  orders         Order[]
  returnRequests ReturnRequest[]
  sales          Sale[]

  @@map("clients")
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String?     @unique @map("order_number")
  clientId        String?     @map("client_id")
  condition       String?
  agency          String?
  observations    String?
  totalAmount     Float       @default(0) @map("total_amount")
  totalQuantity   Int         @default(0) @map("total_quantity")
  status          String      @default("PENDIENTE")
  sellerId        String      @map("seller_id")
  zone            String?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  needsResend     Boolean     @default(false) @map("needs_resend")
  dispatchDetails Json?       @map("dispatch_details")
  annulledAt      DateTime?   @map("annulled_at")
  annulledById    String?     @map("annulled_by_id")
  annulledByName  String?     @map("annulled_by_name")
  annulledByRole  String?     @map("annulled_by_role")
  deliveryAddress String?     @map("delivery_address")
  items           OrderItem[]
  client          Client?     @relation(fields: [clientId], references: [id])
  seller          User        @relation("UserOrders", fields: [sellerId], references: [id])

  @@map("orders")
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String   @map("order_id")
  modelName    String   @map("model_name")
  color        String
  s28          Int      @default(0)
  m30          Int      @default(0)
  l32          Int      @default(0)
  xl34         Int      @default(0)
  xxl36        Int      @default(0)
  size38       Int      @default(0)
  size40       Int      @default(0)
  size42       Int      @default(0)
  size44       Int      @default(0)
  size46       Int      @default(0)
  quantity     Int      @default(0)
  unitPrice    Float    @map("unit_price")
  totalPrice   Float    @map("total_price")
  createdAt    DateTime @default(now()) @map("created_at")
  dispL32      Int      @default(0) @map("disp_l32")
  dispM30      Int      @default(0) @map("disp_m30")
  dispQuantity Int      @default(0) @map("disp_quantity")
  dispS28      Int      @default(0) @map("disp_s28")
  dispSize38   Int      @default(0) @map("disp_size38")
  dispSize40   Int      @default(0) @map("disp_size40")
  dispSize42   Int      @default(0) @map("disp_size42")
  dispSize44   Int      @default(0) @map("disp_size44")
  dispSize46   Int      @default(0) @map("disp_size46")
  dispXL34     Int      @default(0) @map("disp_xl34")
  dispXXL36    Int      @default(0) @map("disp_xxl36")
  dispSize48   Int      @default(0) @map("disp_size48")
  dispSize50   Int      @default(0) @map("disp_size50")
  dispSize52   Int      @default(0) @map("disp_size52")
  size48       Int      @default(0)
  size50       Int      @default(0)
  size52       Int      @default(0)
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model Sale {
  id               String        @id @default(cuid())
  invoiceNumber    String?       @unique @map("invoice_number")
  clientId         String?       @map("client_id")
  totalAmount      Float         @map("total_amount")
  paymentMethod    String        @map("payment_method")
  status           String        @default("COMPLETADO")
  sellerId         String        @map("seller_id")
  notes            String?
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  paymentStatus    String        @default("PENDIENTE") @map("payment_status")
  sunatCdrUrl      String?       @map("sunat_cdr_url")
  sunatPdfUrl      String?       @map("sunat_pdf_url")
  sunatResponse    String?       @map("sunat_response")
  sunatStatus      String?       @map("sunat_status")
  sunatXmlUrl      String?       @map("sunat_xml_url")
  totalCost        Float         @default(0) @map("total_cost")
  referralGuide    String?       @map("referral_guide")
  sunatGuidePdfUrl String?       @map("sunat_guide_pdf_url")
  cargoUrl         String?       @map("cargo_url")
  deliveryAddress  String?       @map("delivery_address")
  letraGroupId     String?       @map("letra_group_id")
  items            SaleItem[]
  payments         SalePayment[]
  client           Client?       @relation(fields: [clientId], references: [id])
  letraGroup       LetraGroup?   @relation("LetraGroupSales", fields: [letraGroupId], references: [id])
  seller           User          @relation("UserSales", fields: [sellerId], references: [id])

  @@map("sales")
}

model SalePayment {
  id               String        @id @default(cuid())
  saleId           String        @map("sale_id")
  amount           Float
  paymentDate      DateTime      @default(now()) @map("payment_date")
  method           String
  evidenceUrl      String?       @map("evidence_url")
  notes            String?
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  registeredById   String?       @map("registered_by_id")
  registeredByName String?       @map("registered_by_name")
  status           String        @default("APROBADO")
  creditNoteMotive String?       @map("credit_note_motive")
  creditNoteNumber String?       @map("credit_note_number")
  sunatCdrUrl      String?       @map("sunat_cdr_url")
  sunatPdfUrl      String?       @map("sunat_pdf_url")
  sunatResponse    String?       @map("sunat_response")
  sunatStatus      String?       @map("sunat_status")
  sunatXmlUrl      String?       @map("sunat_xml_url")
  letraDetails     LetraDetail[]
  sale             Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("sale_payments")
}

model LetraDetail {
  id           String      @id @default(cuid())
  paymentId    String      @map("payment_id")
  number       Int
  dueDate      DateTime    @map("due_date")
  amount       Float
  uniqueNumber String?     @map("unique_number")
  observation  String?
  status       String      @default("PENDIENTE")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  payment      SalePayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("letra_details")
}

model SaleItem {
  id         String         @id @default(cuid())
  saleId     String         @map("sale_id")
  variantId  String         @map("variant_id")
  quantity   Float
  unitPrice  Float          @map("unit_price")
  totalPrice Float          @map("total_price")
  createdAt  DateTime       @default(now()) @map("created_at")
  costPrice  Float          @default(0) @map("cost_price")
  sale       Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variant    ProductVariant @relation(fields: [variantId], references: [id])

  @@map("sale_items")
}

model ProductSample {
  id                    String           @id @default(cuid())
  name                  String
  description           String?
  characteristics       String?
  images                String[]
  status                String           @default("PENDIENTE")
  observations          String?
  recommendations       String?
  op                    String?
  productionQuantity    Float?           @map("production_quantity")
  productionColor       String?          @map("production_color")
  productionSizeData    Json?            @map("production_size_data")
  udpId                 String           @map("udp_id")
  commercialId          String?          @map("commercial_id")
  approvedAt            DateTime?        @map("approved_at")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")
  adminMaterialNotes    String?          @map("admin_material_notes")
  logisticsMaterialDate DateTime?        @map("logistics_material_date")
  materialReceiptStatus String?          @default("PENDIENTE_ADMIN") @map("material_receipt_status")
  udpMaterialReceivedAt DateTime?        @map("udp_material_received_at")
  code                  String?          @unique
  udpRequirements       Json?            @map("udp_requirements")
  adminOpApprovalStatus String           @default("PENDIENTE") @map("admin_op_approval_status")
  barcode               String?
  processAudits         ProcessAudit[]
  commercial            User?            @relation("SampleReviewer", fields: [commercialId], references: [id])
  udp                   User             @relation("SampleCreator", fields: [udpId], references: [id])
  materials             SampleMaterial[]

  @@map("product_samples")
}

model SampleMaterial {
  id              String        @id @default(cuid())
  sampleId        String        @map("sample_id")
  productId       String?       @map("product_id")
  unitPriceAtTime Float         @map("unit_price_at_time")
  createdAt       DateTime      @default(now()) @map("created_at")
  customMaterial  String?       @map("custom_material")
  quantity        Float         @default(1)
  product         Product?      @relation(fields: [productId], references: [id])
  sample          ProductSample @relation(fields: [sampleId], references: [id], onDelete: Cascade)

  @@map("sample_materials")
}

model Agency {
  id          String   @id @default(cuid())
  name        String
  address     String?
  phone       String?
  zone        String
  ruc         String?
  contactName String?  @map("contact_name")
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdBy   User     @relation("AgencyCreator", fields: [createdById], references: [id])

  @@map("agencies")
}

model InvoiceConfig {
  id         String @id @default(cuid())
  type       String @unique
  series     String
  nextNumber Int    @default(1)

  @@map("invoice_configs")
}

model ReturnRequest {
  id                  String              @id @default(cuid())
  returnNumber        String              @unique @map("return_number")
  clientId            String              @map("client_id")
  sellerId            String              @map("seller_id")
  status              String              @default("PENDIENTE_COMERCIAL")
  reason              String
  evidenceUrl         String?             @map("evidence_url")
  rejectionReason     String?             @map("rejection_reason")
  qualityObservations String?             @map("quality_observations")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  items               ReturnRequestItem[]
  client              Client              @relation(fields: [clientId], references: [id])
  seller              User                @relation("UserReturnRequests", fields: [sellerId], references: [id])

  @@map("return_requests")
}

model ReturnRequestItem {
  id              String        @id @default(cuid())
  returnRequestId String        @map("return_request_id")
  modelName       String        @map("model_name")
  color           String
  s28             Int           @default(0)
  m30             Int           @default(0)
  l32             Int           @default(0)
  xl34            Int           @default(0)
  xxl36           Int           @default(0)
  size38          Int           @default(0)
  size40          Int           @default(0)
  size42          Int           @default(0)
  size44          Int           @default(0)
  size46          Int           @default(0)
  quantity        Int           @default(0)
  size48          Int           @default(0)
  size50          Int           @default(0)
  size52          Int           @default(0)
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)

  @@map("return_request_items")
}

model Employee {
  id             String      @id @default(cuid())
  name           String
  documentNumber String      @unique @map("document_number")
  phone          String?
  email          String?
  hourlyRate     Float       @map("hourly_rate")
  isActive       Boolean     @default(true) @map("is_active")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  shifts         WorkShift[]

  @@map("employees")
}

model WorkShift {
  id           String   @id @default(cuid())
  employeeId   String   @map("employee_id")
  date         DateTime
  startTime    DateTime @map("start_time")
  endTime      DateTime @map("end_time")
  hoursWorked  Float    @map("hours_worked")
  totalPayment Float    @map("total_payment")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  status       String   @default("ASISTIO")
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("work_shifts")
}

model LetraGroup {
  id                String           @id @default(cuid())
  clientId          String           @map("client_id")
  totalSalesAmount  Float            @map("total_sales_amount")
  totalLetrasAmount Float            @map("total_letras_amount")
  pendingBalance    Float            @map("pending_balance")
  status            String           @default("PENDIENTE")
  notes             String?
  registeredById    String?          @map("registered_by_id")
  registeredByName  String?          @map("registered_by_name")
  creditNoteNumber  String?          @map("credit_note_number")
  creditNoteMotive  String?          @map("credit_note_motive")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  letras            LetraGroupItem[]
  client            Client           @relation(fields: [clientId], references: [id])
  sales             Sale[]           @relation("LetraGroupSales")

  @@map("letra_groups")
}

model LetraGroupItem {
  id           String     @id @default(cuid())
  groupId      String     @map("group_id")
  number       Int
  dueDate      DateTime   @map("due_date")
  amount       Float
  uniqueNumber String?    @map("unique_number")
  observation  String?
  status       String     @default("PENDIENTE")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  paymentDate  DateTime?  @map("payment_date")
  paymentNotes String?    @map("payment_notes")
  voucherUrl   String?    @map("voucher_url")
  group        LetraGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("letra_group_items")
}
