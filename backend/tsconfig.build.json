{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",       // Donde se genera el build
    "rootDir": "src",       // Desde dónde se compila
    "removeComments": true,
    "declaration": false    // No necesitamos .d.ts en producción
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts"]
}